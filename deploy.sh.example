#!/bin/bash
set -euo pipefail

# =============================================================
# Deploy script for Kira-Kira OshareQuiz
# Usage:
#   ./deploy.sh              Deploy everything (backend first, then frontend)
#   ./deploy.sh frontend     Deploy frontend to S3 + invalidate CloudFront
#   ./deploy.sh backend      Deploy backend via SAM (Lambda + API Gateway + DynamoDB)
# =============================================================

# --- Configuration (fill in your values) ---
AWS_PROFILE="YOUR_AWS_PROFILE"
FRONTEND_BUCKET="YOUR_S3_BUCKET_NAME"
CF_DISTRIBUTION_ID="YOUR_CLOUDFRONT_DISTRIBUTION_ID"

# プロファイルを全 aws / sam コマンドに適用
export AWS_PROFILE

# --- Functions ---

deploy_backend() {
  echo "========================================="
  echo " Building & deploying backend (SAM)..."
  echo " Profile: ${AWS_PROFILE}"
  echo "========================================="
  cd backend/src && npm install && cd ..
  sam build
  sam deploy
  cd ..
  echo "Backend deployment complete."
  echo ""
}

deploy_frontend() {
  echo "========================================="
  echo " Deploying frontend..."
  echo " Profile: ${AWS_PROFILE}"
  echo "========================================="

  # Vite ビルド
  cd frontend
  npm install
  npm run build
  echo ""

  # S3 へアップロード
  echo "Uploading to s3://${FRONTEND_BUCKET} ..."
  aws s3 sync dist/ "s3://${FRONTEND_BUCKET}" --delete
  echo ""

  # index.html のキャッシュ制御（短い TTL で SPA の更新を即反映）
  aws s3 cp "s3://${FRONTEND_BUCKET}/index.html" "s3://${FRONTEND_BUCKET}/index.html" \
    --cache-control "max-age=60" \
    --content-type "text/html" \
    --metadata-directive REPLACE

  # CloudFront キャッシュ無効化
  if [ -n "${CF_DISTRIBUTION_ID}" ] && [ "${CF_DISTRIBUTION_ID}" != "YOUR_CLOUDFRONT_DISTRIBUTION_ID" ]; then
    echo "Invalidating CloudFront cache..."
    aws cloudfront create-invalidation \
      --distribution-id "${CF_DISTRIBUTION_ID}" \
      --paths "/*" \
      --output text
  else
    echo "Skipping CloudFront invalidation (distribution ID not configured)."
  fi

  cd ..
  echo "Frontend deployment complete."
  echo ""
}

# --- Main ---

case "${1:-all}" in
  frontend)
    deploy_frontend
    ;;
  backend)
    deploy_backend
    ;;
  all)
    deploy_backend
    deploy_frontend
    ;;
  *)
    echo "Usage: $0 {frontend|backend|all}"
    exit 1
    ;;
esac

echo "Done!"
