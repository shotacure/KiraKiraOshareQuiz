export const PLAYER_NAME_KEY = 'quiz_player_name';
export const ADMIN_SECRET_KEY = 'quiz_admin_secret';
export const DISPLAY_SECRET_KEY = 'quiz_display_secret';

// Route paths (change these to your own obscure paths)
