  PLAYER: '/',
  ADMIN: '/control',
  DISPLAY: '/screen',
};

export const STATUS = {
  INIT: 'init',
  ACCEPTING: 'accepting',
  ANSWERING: 'answering',
  JUDGING: 'judging',
  SHOWING_ANSWER: 'showing_answer',
  SHOWING_SCORES: 'showing_scores',
};
